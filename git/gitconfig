[init]
  defaultBranch = main

[branch]
  autosetuprebase = always

[pull]
  rebase = true

[format]
  signoff = true

[grep]
  linenumber = true

[push]
  default = simple

[color]
  ui = true

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff-highlight"]
  oldNormal = red bold
  oldHighlight = red bold 52
  newNormal = green bold
  newHighlight = green bold 22

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[merge]
  ff            = false
  tool          = vimdiff
  log           = true
  conflictstyle = diff3

[help]
  autocorrect = 1

[alias]
  d = diff --patience
  br = branch
  ci = commit -a
  co = checkout
  st = status

  up = pull
  upstream = remote add upstream
  lg = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)'
  lgo = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  lga = log --graph --all --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative

[diff]
  colorMoved = default

[delta]
    navigate     = true    # use n and N to move between diff sections
    light        = false      # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
    side-by-side = true
    line-numbers = true

[core]
  excludesfile = ~/.gitignore
  whitespace   = space-before-tab,-indent-with-non-tab,trailing-space
  trustctime   = false
  editor       = vim
  pager        = delta

[interactive]
  diffFilter = delta --color-only

[add.interactive]
  useBuiltin = false # required for git 2.37.0

[include]
  path = ~/.private/gitconfig

[IncludeIf "gitdir:/Users"]
  path = ~/.gitconfig-osx
[IncludeIf "gitdir:/home"]
  path = ~/.gitconfig-linux
[IncludeIf "gitdir:C:"]
  path = ~/.gitconfig-windows

[url "https://github.com/zsh-users"]
  insteadOf = http://github.com/zsh-users
  insteadOf = ssh://git@github.com/zsh-users

[url "ssh://git@github.com/"]
  insteadOf = gh:
  insteadOf = ghub:
  insteadOf = github:
  insteadOf = http://github.com/
  insteadOf = https://github.com/
